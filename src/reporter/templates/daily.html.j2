<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>空运新闻速递 - {{ date_str }}</title>
<style>
:root {
    --bg: #f5f5f7; --bg-elevated: #ffffff; --text: #1d1d1f;
    --text-secondary: #86868b; --text-tertiary: #aeaeb2;
    --border: #d2d2d7; --fill: #e8e8ed; --accent: #0071e3;
    --red: #ff3b30; --green: #34c759; --purple: #af52de; --blue: #007aff;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
    --shadow: 0 4px 12px rgba(0,0,0,0.06);
}
@media (prefers-color-scheme: dark) {
    :root {
        --bg: #000; --bg-elevated: #1c1c1e; --text: #f5f5f7;
        --text-secondary: #98989d; --text-tertiary: #636366;
        --border: #38383a; --fill: #2c2c2e; --accent: #0a84ff;
        --red: #ff453a; --green: #30d158; --purple: #bf5af2;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.3);
        --shadow: 0 4px 12px rgba(0,0,0,0.4);
    }
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Noto Sans SC", "PingFang SC", sans-serif;
    background: var(--bg); color: var(--text); line-height: 1.5;
    -webkit-font-smoothing: antialiased; max-width: 860px; margin: 0 auto; padding: 40px 24px 80px;
}
.header { text-align: center; padding: 0 0 32px; }
.header h1 { font-size: 32px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 6px; }
.header .meta { font-size: 14px; color: var(--text-secondary); }
.section-title {
    font-size: 17px; font-weight: 600; margin: 28px 0 12px;
    padding-bottom: 8px; color: var(--text-secondary);
    border-bottom: 0.5px solid var(--border); letter-spacing: -0.2px;
}
.card {
    background: var(--bg-elevated); border-radius: 18px;
    padding: 20px 22px; margin-bottom: 10px;
    box-shadow: var(--shadow-sm); border: 0.5px solid var(--border);
}
.card-title { font-size: 16px; font-weight: 600; margin-bottom: 10px; letter-spacing: -0.2px; }
.card-title a { color: var(--text); text-decoration: none; }
.card-title a:hover { color: var(--accent); }
.card-meta-rows { margin-bottom: 10px; }
.meta-row { font-size: 12px; line-height: 2.2; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.meta-label { color: var(--text-tertiary); font-size: 11px; font-weight: 500; min-width: 30px; text-transform: uppercase; letter-spacing: 0.3px; }
.meta-date { color: var(--text-tertiary); font-size: 11px; margin-left: 8px; }
.badge { display: inline-block; font-size: 11px; padding: 3px 10px; border-radius: 20px; font-weight: 500; }
.badge-source { background: rgba(175,82,222,0.12); color: var(--purple); }
.badge-cat { background: rgba(52,199,89,0.12); color: var(--green); }
.badge-region { background: rgba(0,122,255,0.1); color: var(--blue); }
.badge-china { background: rgba(255,59,48,0.1); color: var(--red); }
.card-summary { font-size: 14px; line-height: 1.6; margin-bottom: 6px; }
.card-tags { display: flex; flex-wrap: wrap; gap: 5px; margin: 10px 0 6px; }
.tag { font-size: 11px; padding: 3px 10px; border-radius: 20px; background: var(--fill); color: var(--text-secondary); }
.expand-btn { color: var(--accent); font-size: 13px; cursor: pointer; border: none; background: none; padding: 6px 0; font-weight: 500; }
.card-body { display: none; margin-top: 12px; padding: 16px 18px; background: var(--fill); border-radius: 12px; font-size: 14px; line-height: 1.7; border: 0.5px solid var(--border); }
.card-body.show { display: block; }
.core-extract { margin: 12px 0; padding: 14px 16px; background: rgba(0,113,227,0.04); border-left: 3px solid var(--accent); border-radius: 0 12px 12px 0; }
.core-label { font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--accent); letter-spacing: 0.5px; margin-bottom: 6px; }
.core-text { font-size: 14px; color: var(--text); line-height: 1.8; }
.core-text p { margin: 0 0 6px; }
.core-text p:last-child { margin: 0; }
@media (prefers-color-scheme: dark) { .core-extract { background: rgba(10,132,255,0.08); } }
.tag-cloud { text-align: center; padding: 20px 0; }
.tag-cloud .tag { cursor: default; margin: 4px; display: inline-block; }
.footer { text-align: center; padding: 40px 0 20px; color: var(--text-tertiary); font-size: 12px; }
@media (prefers-color-scheme: dark) {
    .badge-source { background: rgba(191,90,242,0.2); }
    .badge-cat { background: rgba(48,209,88,0.18); }
    .badge-region { background: rgba(10,132,255,0.18); }
    .badge-china { background: rgba(255,69,58,0.2); }
}
@media (max-width: 640px) { body { padding: 20px 16px; } .header h1 { font-size: 24px; } }
</style>
</head>
<body>
<div class="header">
    <h1>空运新闻速递</h1>
    <div class="meta">{{ date_display }} | 共 {{ total_count }} 条新闻 | 来源: {{ sources }}</div>
</div>
{% for cat_id, cat_name, cat_items in categories %}{% if cat_items %}
<div class="section-title">{{ cat_name }} ({{ cat_items|length }})</div>
{% for news in cat_items %}
<div class="card">
    <div class="card-title"><a href="{{ news.url }}" target="_blank">{{ news.translated_title or news.title }}</a></div>
    <div class="card-meta-rows">
        <div class="meta-row"><span class="meta-label">来源</span> <span class="badge badge-source">{{ news.source }}</span>{% if news.published_at %} <span class="meta-date">{{ news.published_at[:10] }}</span>{% endif %}</div>
        <div class="meta-row"><span class="meta-label">分类</span> {% for label in news.get_category_labels() %}<span class="badge badge-cat">{{ label }}</span>{% endfor %}</div>
        <div class="meta-row"><span class="meta-label">区域</span> {% for r in news.get_regions_list() %}<span class="badge {{ 'badge-china' if r == 'China' else 'badge-region' }}">{{ REGION_LABELS[r] }}</span>{% endfor %}</div>
    </div>
    <div class="card-summary">{{ news.summary }}</div>
    {% if news.core_extract %}
    <div class="core-extract">
        <div class="core-label">新闻核心</div>
        <div class="core-text">{% for line in news.core_extract.split('\n') %}{% if line.strip() %}<p>{{ line.strip() }}</p>{% endif %}{% endfor %}</div>
    </div>
    {% endif %}
    <div class="card-tags">{% for kw in news.get_keywords_list() %}<span class="tag">{{ kw }}</span>{% endfor %}</div>
    <button class="expand-btn" onclick="this.nextElementSibling.classList.toggle('show');this.textContent=this.nextElementSibling.classList.contains('show')?'收起全文 ▲':'展开全文 ▼'">展开全文 ▼</button>
    <div class="card-body">{{ news.translated_text or news.original_text }}</div>
</div>
{% endfor %}{% endif %}{% endfor %}
{% if all_keywords %}
<div class="tag-cloud">
    <div style="font-size:14px;color:var(--text-secondary);margin-bottom:12px;">关键词云</div>
    {% for kw, size in all_keywords %}<span class="tag" style="font-size:{{ size }}px;">{{ kw }}</span>{% endfor %}
</div>
{% endif %}
<div class="footer">空运新闻速递 | {{ date_str }}</div>
</body>
</html>
